Panels:
  - Class: rviz_common/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
      Splitter Ratio: 0.5
    Tree Height: 70
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded: ~
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: mmp_rviz_plugins/MapSelector
    Name: MMP Control
  - Class: mmp_rviz_plugins/TrajectoryCommand
    Name: TrajectoryCommand
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 1
      Class: rviz_default_plugins/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.029999999329447746
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 10
      Reference Frame: <Fixed Frame>
      Value: true
    - Alpha: 0.8999999761581421
      Autocompute Intensity Bounds: false
      Class: grid_map_rviz_plugin/GridMap
      Color: 0; 0; 128
      Color Layer: water
      Color Transformer: FlatColor
      Enabled: true
      Height Layer: water
      Height Transformer: GridMapLayer
      History Length: 1
      Invert Rainbow: false
      Max Color: 0; 64; 128
      Max Intensity: 1
      Min Color: 0; 64; 128
      Min Intensity: 0
      Name: Water
      Show Grid Lines: false
      Topic:
        Depth: 5
        Durability Policy: Transient Local
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /terrain/grid_map
      Use Rainbow: false
      Value: true
    - Alpha: 1
      Autocompute Intensity Bounds: true
      Class: grid_map_rviz_plugin/GridMap
      Color: 200; 200; 200
      Color Layer: hillshade
      Color Transformer: GridMapLayer
      Enabled: true
      Height Layer: elevation
      Height Transformer: GridMapLayer
      History Length: 1
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 10
      Min Color: 139; 90; 43
      Min Intensity: 0
      Name: Terrain
      Show Grid Lines: false
      Topic:
        Depth: 5
        Durability Policy: Transient Local
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /terrain/grid_map
      Use Rainbow: false
      Value: true
    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: Path and Obstacles
      Namespaces:
        {}
      Topic:
        Depth: 20
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /path_markers
      Value: true
    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: Min Jerk Trajectory
